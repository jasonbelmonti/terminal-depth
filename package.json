{
  "name": "terminal-depth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.30.3"
  },
  "scripts": {
    "install:workspace": "pnpm install",
    "dev": "pnpm --recursive --parallel --if-present dev",
    "build": "pnpm --recursive --if-present build",
    "typecheck": "pnpm exec tsc --project tsconfig.json --pretty false && pnpm --recursive --if-present typecheck",
    "test": "pnpm --recursive --if-present test",
    "test:watch": "pnpm --recursive --parallel --if-present test:watch"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
