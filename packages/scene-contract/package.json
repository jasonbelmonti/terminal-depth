{
  "name": "@terminal-depth/scene-contract",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./fixtures": {
      "types": "./src/fixtures/index.ts",
      "import": "./src/fixtures/index.ts"
    }
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./fixtures": {
        "types": "./dist/fixtures/index.d.ts",
        "import": "./dist/fixtures/index.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm exec tsc --project tsconfig.json --pretty false",
    "typecheck": "pnpm exec tsc --project tsconfig.json --pretty false --noEmit"
  }
}
